{% doc %}
  @prompt
    I need exact same layout like in  image accodian content left side main title and right side question and answer with drop down and plus and minue icons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-accordion-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.title_column_width }}% 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: start;
  }

  .ai-accordion-title-column-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-accordion-main-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.main_title_size }}px;
    color: {{ block.settings.main_title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-accordion-items-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.item_background }};
  }

  .ai-accordion-header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.3s ease;
  }

  .ai-accordion-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.item_hover_background }};
  }

  .ai-accordion-question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    font-weight: {{ block.settings.question_weight }};
    margin: 0;
    padding-right: 20px;
  }

  .ai-accordion-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-accordion-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-accordion-item-{{ ai_gen_id }}.active .ai-accordion-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-accordion-content-inner-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.item_padding }}px {{ block.settings.item_padding }}px;
  }

  .ai-accordion-answer-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_title_spacing }}px;
    }

    .ai-accordion-title-column-{{ ai_gen_id }} {
      position: static;
    }

    .ai-accordion-main-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_title_size | times: 0.8 }}px;
    }

    .ai-accordion-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
    }

    .ai-accordion-answer-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<accordion-block-{{ ai_gen_id }} class="ai-accordion-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-accordion-container-{{ ai_gen_id }}">
    <div class="ai-accordion-title-column-{{ ai_gen_id }}">
      {% if block.settings.main_title != blank %}
        <h2 class="ai-accordion-main-title-{{ ai_gen_id }}">{{ block.settings.main_title }}</h2>
      {% endif %}
    </div>

    <div class="ai-accordion-items-column-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign question_key = 'question_' | append: i
          assign answer_key = 'answer_' | append: i
          assign question = block.settings[question_key]
          assign answer = block.settings[answer_key]
        %}

        {% if question != blank %}
          <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
            <button
              class="ai-accordion-header-{{ ai_gen_id }}"
              aria-expanded="false"
              data-accordion-trigger
            >
              <h3 class="ai-accordion-question-{{ ai_gen_id }}">{{ question }}</h3>
              <div class="ai-accordion-icon-{{ ai_gen_id }}">
                {% if block.settings.icon_style == 'plus_minus' %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19" class="ai-accordion-icon-vertical-{{ ai_gen_id }}"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                {% endif %}
              </div>
            </button>
            <div class="ai-accordion-content-{{ ai_gen_id }}" data-accordion-content>
              <div class="ai-accordion-content-inner-{{ ai_gen_id }}">
                {% if answer != blank %}
                  <div class="ai-accordion-answer-{{ ai_gen_id }}">{{ answer }}</div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</accordion-block-{{ ai_gen_id }}>

<script>
  (function() {
    class AccordionBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-accordion-item]');
        this.setupAccordion();
      }

      setupAccordion() {
        this.items.forEach((item) => {
          const trigger = item.querySelector('[data-accordion-trigger]');
          const content = item.querySelector('[data-accordion-content]');
          const contentInner = content.querySelector('.ai-accordion-content-inner-{{ ai_gen_id }}');

          trigger.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            if (isActive) {
              this.closeItem(item, trigger, content);
            } else {
              this.items.forEach((otherItem) => {
                if (otherItem !== item && otherItem.classList.contains('active')) {
                  const otherTrigger = otherItem.querySelector('[data-accordion-trigger]');
                  const otherContent = otherItem.querySelector('[data-accordion-content]');
                  this.closeItem(otherItem, otherTrigger, otherContent);
                }
              });

              this.openItem(item, trigger, content, contentInner);
            }
          });
        });
      }

      openItem(item, trigger, content, contentInner) {
        item.classList.add('active');
        trigger.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = contentInner.scrollHeight + 'px';
      }

      closeItem(item, trigger, content) {
        item.classList.remove('active');
        trigger.setAttribute('aria-expanded', 'false');
        content.style.maxHeight = '0';
      }
    }

    customElements.define('accordion-block-{{ ai_gen_id }}', AccordionBlock{{ ai_gen_id }});
  })();
</script>

